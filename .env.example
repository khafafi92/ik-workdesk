APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


# ─── MAIL / EMAIL NOTIFICATION ────────────────────────────────────────────────
# Default mailer (gunakan 'log' untuk testing lokal, 'smtp' untuk production)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@perusahaan.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── SMTP Perusahaan 1: KPMOG (@kpmog.com) ────────────────────────────────────
# User dengan email @kpmog.com akan menerima notif via SMTP ini
MAIL_KPMOG_HOST=mail.kpmog.com
MAIL_KPMOG_PORT=465
MAIL_KPMOG_USERNAME=tiket@kpmog.com
MAIL_KPMOG_PASSWORD=password_email_tiket_kpmog
MAIL_KPMOG_ENCRYPTION=ssl
MAIL_KPMOG_FROM_ADDRESS=tiket@kpmog.com
MAIL_KPMOG_FROM_NAME="Internal 9"

# ─── SMTP Perusahaan 2: APCA (@apca.com) ──────────────────────────────────────
# User dengan email @apca.com akan menerima notif via SMTP ini
MAIL_APCA_HOST=mail.apca.com
MAIL_APCA_PORT=465
MAIL_APCA_USERNAME=tiket@apca.com
MAIL_APCA_PASSWORD=password_email_tiket_apca
MAIL_APCA_ENCRYPTION=ssl
MAIL_APCA_FROM_ADDRESS=tiket@apca.com
MAIL_APCA_FROM_NAME="Internal 9"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
